<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ── TOP BAR ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/white"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_circle_outline"
            android:scaleType="centerCrop"
            android:src="@drawable/arrow"
            android:contentDescription="Back" />

        <!-- Search Input -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="10dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/search"
                android:contentDescription="Search"
                app:tint="@color/text_secondary" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="Search services..."
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:background="@null"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Clear X button (visible when typing) -->
            <ImageButton
                android:id="@+id/btnClear"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@null"
                android:src="@drawable/close"
                android:contentDescription="Clear"
                android:visibility="gone"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <!-- Filter button -->
        <LinearLayout
            android:id="@+id/btnFilter"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:background="@drawable/bg_filter_button">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/filter"
                android:contentDescription="Filter"
                app:tint="@color/primary" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Cancel"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:padding="4dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider" />

    <!-- ── LOADING BAR ───────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- ── RESULT COUNT (shown during search) ───────────────── -->
    <TextView
        android:id="@+id/tvResultCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <!-- ── EMPTY STATE ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="40sp" />

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No services found"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════
         RECENT + POPULAR (shown when search bar is empty)
         ════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/layoutRecent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp">

            <!-- Recent Searches label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recent Searches"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <!-- Recent item 1 -->
            <LinearLayout
                android:id="@+id/recentItem1"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/history"
                    android:contentDescription="Recent"
                    android:layout_marginEnd="12dp"
                   />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="House Cleaning"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/close"
                    android:contentDescription="Remove"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider" />

            <!-- Recent item 2 -->
            <LinearLayout
                android:id="@+id/recentItem2"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/history"
                    android:contentDescription="Recent"
                    android:layout_marginEnd="12dp"
                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Plumbing"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/close"
                    android:contentDescription="Remove"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider" />

            <!-- Recent item 3 -->
            <LinearLayout
                android:id="@+id/recentItem3"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/history"
                    android:contentDescription="Recent"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Electrician"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/close"
                    android:contentDescription="Remove"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/divider" />

            <!-- Recent item 4 -->
            <LinearLayout
                android:id="@+id/recentItem4"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/history"
                    android:contentDescription="Recent"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Carpentry"
                    android:textSize="13sp"
                   />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/close"
                    android:contentDescription="Remove"
                 />

            </LinearLayout>

            <!-- Popular Categories label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Popular Categories"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <!-- Category grid row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Cleaning -->
                <LinearLayout
                    android:id="@+id/catCleaning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/cleaning"
                            android:contentDescription="Cleaning" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cleaning"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <!-- Plumbing -->
                <LinearLayout
                    android:id="@+id/catPlumbing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_plumbing"
                            android:contentDescription="Plumbing" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plumbing"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <!-- Electrician -->
                <LinearLayout
                    android:id="@+id/catElectrician"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/electrician"
                            android:contentDescription="Electrician" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electrician"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <!-- Carpentry -->
                <LinearLayout
                    android:id="@+id/catCarpentry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/img_4"
                            android:contentDescription="Carpentry" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carpentry"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Category grid row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- AC Repair -->
                <LinearLayout
                    android:id="@+id/catAcRepair"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ac"
                            android:contentDescription="AC Repair" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AC Repair"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <!-- Gardening -->
                <LinearLayout
                    android:id="@+id/catGardening"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/gurden"
                            android:contentDescription="Gardening" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gardening"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <!-- Painting -->
                <LinearLayout
                    android:id="@+id/catPainting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/painting"
                            android:contentDescription="Painting" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Painting"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

                <!-- More -->
                <LinearLayout
                    android:id="@+id/catMore"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="@drawable/bg_category_icon">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/more"
                            android:contentDescription="More" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="More"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════════════════
         SEARCH RESULTS (shown when typing)
         ════════════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        android:visibility="gone" />

</LinearLayout>