<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="5dp"
    android:paddingStart="0dp"
    android:paddingEnd="60dp"
    android:gravity="bottom">

    <!-- Avatar -->
    <TextView
        android:id="@+id/tvInitials"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="JD"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#5F5E5A"
        android:background="@drawable/bg_avatar_gray_circle"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="0dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_received"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="Hey! Are you free this weekend?"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginStart="4dp"
            android:text="10:28 AM"
            android:textColor="#AAAAAA"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>